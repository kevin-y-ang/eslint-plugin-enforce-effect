{
  "name": "@kevin-y-ang/eslint-plugin-enforce-effect",
  "version": "0.1.0",
  "description": "ESLint plugin skeleton for enforcing Effect-oriented patterns in TypeScript codebases.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:fixtures": "vitest run tests/fixtures/eslint-cli.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "check": "eslint . && tsc -p tsconfig.json && vitest run",
    "prepack": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "effect",
    "typescript",
    "typescript-eslint"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kevin-y-ang/eslint-plugin-enforce-effect.git"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.58.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/rule-tester": "^8.58.0",
    "eslint": "^10.1.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2",
    "@typescript-eslint/parser": "^8.58.0"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "typescript": ">=4.8.4 <6.1.0"
  }
}
